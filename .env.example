# ═══════════════════════════════════════════════════════════════════════
# ContractEnv — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════════
# ⚠️  WARNING: NEVER commit .env to git!
# Copy this file:  cp .env.example .env
# Then fill in your real values.
# ═══════════════════════════════════════════════════════════════════════

# ── Required: LLM API ────────────────────────────────────────────────
# Base URL for the OpenAI-compatible inference API.
API_BASE_URL=https://api.openai.com/v1

# Model identifier used for counterparty simulation & reward scoring.
MODEL_NAME=gpt-4o-mini

# ── Required: Hugging Face ───────────────────────────────────────────
# HF token with write access (for Spaces deployment).
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# ── Server Configuration ─────────────────────────────────────────────
# Runtime environment flag.
ENVIRONMENT=development

# Logging verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Port the FastAPI server listens on (must match HF Spaces expectation).
PORT=7860

# Number of Uvicorn workers. Keep at 1 for stateful environments.
MAX_WORKERS=1

# ── Deployment ───────────────────────────────────────────────────────
# Public URL of the deployed HF Space (set after first deploy).
SPACE_URL=

# ── Optional: MCP Server ─────────────────────────────────────────────
# URL of an MCP server for tool-augmented negotiation (Phase 3+).
MCP_SERVER_URL=
